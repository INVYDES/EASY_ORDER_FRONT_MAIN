# Configuración de WebSockets (Reverb)
VITE_REVERB_HOST=corion.mx
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_APP_KEY=ds9d0dge2etayrnrzaca

# Opcional: Timeout para peticiones largas
VITE_API_TIMEOUT=30000
